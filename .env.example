# Site selection: gsmarena | laptopmedia
SITE=

# =====================
# GSMarena (required when SITE=gsmarena)
# =====================
GSMARENA_BASE_URL=
GSMARENA_MAKERS_PAGE_URL=

# Comma-separated regex patterns matching brand names to scrape
# Leave empty to scrape ALL brands
MAKERS_TO_SCRAPE=

# =====================
# Laptopmedia (required when SITE=laptopmedia)
# =====================
LAPTOPMEDIA_BASE_URL=

# Comma-separated regex patterns matching brand names to scrape
# Leave empty to scrape ALL brands
LAPTOPMEDIA_MAKERS_TO_SCRAPE=

# Max models to scrape per brand (recency-sorted, deduped by series)
# Leave empty for no limit
MAX_PER_BRAND=

# The ones below are shared across all sites, so always required.
REQUEST_DELAY_MS=

# Pipeline step: makers | models | scrape | all
STEP=

# Local directory where downloaded device images will be stored
# Leave empty to skip image downloads
IMAGES_DIR=

# Path to proxy list file (ip:port:username:password per line)
# Leave empty to run without proxy
PROXY_FILE_PATH=
