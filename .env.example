# Base URL for all GSMarena pages
GSMARENA_BASE_URL=https://www.gsmarena.com

# Full URL to the makers page that lists all phone brands
GSMARENA_MAKERS_PAGE_URL=https://www.gsmarena.com/makers.php3

# Delay in milliseconds between HTTP requests (helps avoid getting blocked)
# Leave empty for default 2000ms
# Examples: 500 (fast), 2000 (safe), 5000 (very conservative)
REQUEST_DELAY_MS=2000

# Comma-separated list of brand slugs to scrape
# Leave empty to scrape ALL brands
# Example: apple-phones-48,samsung-phones-9,google-phones-107
BRANDS_TO_SCRAPE=

# Local directory where downloaded device images will be stored
IMAGES_DIR=./data/images/models
