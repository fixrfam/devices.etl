# Base URL for all GSMarena pages
GSMARENA_BASE_URL=https://www.gsmarena.com

# Full URL to the makers page that lists all phone brands
GSMARENA_MAKERS_PAGE_URL=https://www.gsmarena.com/makers.php3

# Delay in milliseconds between HTTP requests (helps avoid getting blocked)
# Leave empty for default 2000ms
# Examples: 500 (fast), 2000 (safe), 5000 (very conservative)
REQUEST_DELAY_MS=2000

# Comma-separated regex patterns matching brand names to scrape
# Leave empty to scrape ALL brands
# Examples:
#   apple,samsung,google          → matches any brand whose name contains these
#   ^apple$                       → exact match (case-insensitive)
#   apple|samsung|google          → regex alternation
MAKERS_TO_SCRAPE=

# Pipeline step to run
# makers   → scrape makers list only
# models   → scrape model listings for each maker
# scrape   → scrape full specs for each model
# all      → run all steps (default)
STEP=all

# Local directory where downloaded device images will be stored
IMAGES_DIR=./data/images/models

# Path to proxy list file (ip:port:username:password per line)
# Proxies are rotated randomly for each request, leave empty to run without proxy
PROXY_FILE_PATH=./data/proxies.txt
